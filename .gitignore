# config-sync.js는 리포에 포함 (양쪽 PC에서 사용)
# 나머지는 sync 스크립트가 복사해오는 파일들만 커밋됨

# OS
Thumbs.db
.DS_Store

# Node 의존성 (notes/ 안 프로젝트들이 끌고 들어옴)
**/node_modules/
**/dist/
**/.next/
**/.cache/

# 잘못된 중첩 경로 (과거 매핑 버그 흔적)
notes/notes/

# 시크릿 (sync 매핑상 이미 제외돼 있지만 belt-and-suspenders)
secrets/
secrets.bak/
.credentials.json
credentials.json
*.token
*.key
*.pem
.env
.env.*

# 대용량 바이너리 덤프 (프린터 드라이버 등) — GitHub 100MB 초과로 push 차단 유발
notes/kyocera/
*.exe
*.msi
