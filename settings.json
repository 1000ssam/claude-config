{
  "deniedMcpServers": [],
  "statusLine": {
    "type": "command",
    "command": "bash -c 'plugin_dir=$(ls -d \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | awk -F/ '\"'\"'{ print $(NF-1) \"\\t\" $0 }'\"'\"' | sort -t. -k1,1n -k2,2n -k3,3n -k4,4n | tail -1 | cut -f2-); exec \"$HOME/.bun/bin/bun\" --env-file /dev/null \"${plugin_dir}src/index.ts\"'"
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": true,
    "claude-hud@claude-hud": true
  },
  "extraKnownMarketplaces": {
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    },
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    }
  },
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "permissions": {
    "allow": [
      "Bash"
    ]
  },
  "effortLevel": "high",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/user/.claude/hooks/gsd-check-update.js\""
          }
        ]
      }
    ],
    "Stop": [],
    "PreCompact": [],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/user/.claude/hooks/gsd-context-monitor.js\""
          }
        ]
      }
    ]
  },
  "model": "sonnet"
}
